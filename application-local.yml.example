# ============================================
# application-local.yml  — 本地开发配置模板
# ============================================
# 使用方式:
#   1. 复制此文件为 application-local.yml
#   2. 填入你的真实密码/密钥（application-local.yml 已在 .gitignore 中排除）
#   3. 启动时指定 profile: --spring.profiles.active=local
#
#   或者直接设置环境变量:
#     DB_PASSWORD=你的密码
#     MINIO_ACCESS_KEY=你的minio账号
#     MINIO_SECRET_KEY=你的minio密码
#     JWT_SECRET=你的jwt签名密钥
# ============================================

spring:
  datasource:
    password: 你的数据库密码

minio:
  accesskey: 你的MinIO账号
  secretKey: 你的MinIO密码

jwt:
  secret: 你的JWT签名密钥
